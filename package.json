{
  "name": "tetris-battle",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/engine",
    "packages/client",
    "packages/server"
  ],
  "scripts": {
    "build": "npm run build:engine && npm run build:client && npm run build:server",
    "build:engine": "cd packages/engine && npx tsc",
    "build:client": "cd packages/client && npx vite build",
    "build:server": "cd packages/server && npx tsc",
    "start": "node packages/server/dist/app.js",
    "dev": "cd packages/server && npx tsx watch src/app.ts"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
